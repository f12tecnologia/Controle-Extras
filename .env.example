# URL do PostgreSQL externo (a mesma usada localmente)
EXTERNAL_DATABASE_URL=postgresql://usuario:senha@host:5432/Dreams_Extras

# SSL do PostgreSQL: auto | true | false (o banco atual usa false/auto sem SSL)
DB_SSL=false

# Porta publicada no host (mapeada para 5000 no container)
APP_PORT=5000

# Superadmin criado/atualizado automaticamente na subida do servidor
SUPERADMIN_EMAIL=admin@intelfoz.com.br
SUPERADMIN_PASSWORD=altere-esta-senha
SUPERADMIN_NAME=Super Admin
